<?xml version="1.0" encoding="utf-8"?>
<service>
  <short>SAP NetWeaver Central Services</short>
  <description>Ports required for SAP NetWeaver Central Services. Maintained by Ansible Role sap_install.sap_swpm.</description>

  {# SAP Host Agent ports for status and metrics communication. -#} 
  <port protocol="tcp" port="1128-1129"/>

  {# SAP Message Server port (36NN). Used for internal communication between application servers. -#}
  <port protocol="tcp" port="36{{ __sap_swpm_firewall_instance_nr }}"/>

  {# SAP Enqueue Server port (39NN). -#}
  <port protocol="tcp" port="39{{ __sap_swpm_firewall_instance_nr }}"/>

  {# SAP Message Server HTTP port (81NN), configured via ms/http_port_<n> profile parameter. -#}
  <port protocol="tcp" port="81{{ __sap_swpm_firewall_instance_nr }}"/>

  {# Ports for SAP Start Service (sapstartsrv) communication. Used for service control and status checks. -#}
  <port protocol="tcp" port="5{{ __sap_swpm_firewall_instance_nr }}13"/>
  <port protocol="tcp" port="5{{ __sap_swpm_firewall_instance_nr }}14"/>
  <port protocol="tcp" port="5{{ __sap_swpm_firewall_instance_nr }}16"/>

</service>